# Copy to `.env` in this folder and set your values.
# LangChain reads OPENAI_API_KEY automatically; OPENAI_MODEL is an alias for CHATBOT_MODEL.

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Optional overrides:
# CHATBOT_BACKEND=openai
# CHATBOT_MODEL=gpt-4o
# CHATBOT_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# CHATBOT_MODEL=llama3
